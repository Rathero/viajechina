# Copia este archivo a .env.local y rellena tus valores de Supabase.
# .env.local NO se sube a git (está en .gitignore).
#
# Settings → API en tu proyecto de Supabase:
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY

# Si dejas estas variables vacías o borras el archivo, la app arranca en
# "modo local" (sin login, un único viaje guardado en el navegador).
